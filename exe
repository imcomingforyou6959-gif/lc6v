-- Auto-Farm (DaHood cash drops)
local function findCashDrops()
    local drops = {}
    for _, v in ipairs(workspace:GetDescendants()) do
        if v.Name == "CashDrop" and v:IsA("Part") then
            table.insert(drops, v)
        end
    end
    return drops
end

RunService.Heartbeat:Connect(function()
    if not Settings.Misc.AutoFarm.Enabled then return end
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local drops = findCashDrops()
    local closest, closestDist = nil, math.huge
    for _, drop in ipairs(drops) do
        local dist = (drop.Position - root.Position).Magnitude
        if dist < closestDist then
            closestDist = dist
            closest = drop
        end
    end
    if closest then
        root.CFrame = CFrame.new(closest.Position + Vector3.new(0, 3, 0))
    end
end)

