        local pos, width, height = getBox(player.Character)
        if not pos then goto continue end

        if myRoot then
            local dist = (myRoot.Position - player.Character.HumanoidRootPart.Position).Magnitude
            if Settings.Visuals.ESP.Distance then
                ui.Name.Text = player.Name .. " [" .. math.floor(dist) .. "m]"
            else
                ui.Name.Text = player.Name
            end
            ui.Name.Position = Vector2.new(pos.X + width/2, pos.Y - 15)
            ui.Name.Visible = Settings.Visuals.ESP.Name
        end

        if Settings.Visuals.ESP.Box then
            ui.Box.Size = Vector2.new(width, height)
            ui.Box.Position = pos
            ui.Box.Color = player.Team == LocalPlayer.Team and Color3.new(0,1,0) or Color3.new(1,0,0)
            ui.Box.Visible = true
        else
            ui.Box.Visible = false
        end

        if Settings.Visuals.ESP.Tracer then
            local startPos = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
            ui.Tracer.From = startPos
            ui.Tracer.To = Vector2.new(pos.X + width/2, pos.Y)
            ui.Tracer.Color = player.Team == LocalPlayer.Team and Color3.new(0,1,0) or Color3.new(1,0,0)
            ui.Tracer.Visible = true
        else
            ui.Tracer.Visible = false
        end

        if Settings.Visuals.ESP.HealthBar then
            local hp = humanoid.Health / humanoid.MaxHealth
            local healthHeight = height * hp
            ui.Health.From = Vector2.new(pos.X - 5, pos.Y + height)
            ui.Health.To = Vector2.new(pos.X - 5, pos.Y + height - healthHeight)
            ui.Health.Color = Color3.fromRGB(255 - (255*hp), 255*hp, 0)
            ui.Health.Visible = true
        else
            ui.Health.Visible = false
        end

        ::continue::
    end
end)

