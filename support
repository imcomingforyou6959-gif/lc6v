-- Dragging functionality
local dragging = false
local dragStart, startPos

TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

TitleBar.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

-- Toggle GUI with key
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == GUI.ToggleKey then
        ScreenGui.Enabled = not ScreenGui.Enabled
    end
end)

-- Helper function to create a toggle in a tab
function CreateToggle(parentTab, text, default, callback)
    local frame = Instance.new("Frame")
    frame.Parent = parentTab
    frame.BackgroundColor3 = GUI.Theme.Secondary
    frame.BorderSizePixel = 0
    frame.Size = UDim2.new(1, -10, 0, 30)
    frame.Position = UDim2.new(0, 5, 0, 0)
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 4)
    corner.Parent = frame
    
    local label = Instance.new("TextLabel")
    label.Parent = frame
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(1, -40, 1, 0)
    label.Position = UDim2.new(0, 10, 0, 0)
    label.Text = text
    label.TextColor3 = GUI.Theme.Text
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    
    local toggle = Instance.new("TextButton")
    toggle.Parent = frame
    toggle.BackgroundColor3 = default and GUI.Theme.Accent or GUI.Theme.Background
    toggle.Size = UDim2.new(0, 30, 0, 20)
    toggle.Position = UDim2.new(1, -40, 0.5, -10)
    toggle.Text = ""
    toggle.AutoButtonColor = false
    toggle.ZIndex = 2
    
    local toggleCorner = Instance.new("UICorner")
    toggleCorner.CornerRadius = UDim.new(0, 4)
    toggleCorner.Parent = toggle
    
    local state = default
    local function updateColor()
        toggle.BackgroundColor3 = state and GUI.Theme.Accent or GUI.Theme.Background
    end
    updateColor()
    
    toggle.MouseButton1Click:Connect(function()
        state = not state
        updateColor()
        if callback then callback(state) end
    end)
    
    return toggle
end

-- Helper function to create a slider
function CreateSlider(parentTab, text, min, max, default, callback)
    local frame = Instance.new("Frame")
    frame.Parent = parentTab
    frame.BackgroundColor3 = GUI.Theme.Secondary
    frame.BorderSizePixel = 0
    frame.Size = UDim2.new(1, -10, 0, 50)
    frame.Position = UDim2.new(0, 5, 0, 0)
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 4)
    corner.Parent = frame
    
    local label = Instance.new("TextLabel")
    label.Parent = frame
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(0.5, -5, 0, 20)
    label.Position = UDim2.new(0, 10, 0, 5)
    label.Text = text
    label.TextColor3 = GUI.Theme.Text
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    
    local valueLabel = Instance.new("TextLabel")
    valueLabel.Parent = frame
    valueLabel.BackgroundTransparency = 1
    valueLabel.Size = UDim2.new(0.5, -5, 0, 20)
    valueLabel.Position = UDim2.new(0.5, 0, 0, 5)
    valueLabel.Text = tostring(default)
    valueLabel.TextColor3 = GUI.Theme.Accent
    valueLabel.TextXAlignment = Enum.TextXAlignment.Right
    valueLabel.Font = Enum.Font.Gotham
    valueLabel.TextSize = 14
    
    local sliderBg = Instance.new("Frame")
    sliderBg.Parent = frame
    sliderBg.BackgroundColor3 = GUI.Theme.Background
    sliderBg.BorderSizePixel = 0
    sliderBg.Size = UDim2.new(1, -20, 0, 6)
    sliderBg.Position = UDim2.new(0, 10, 0, 30)
    
    local sliderBgCorner = Instance.new("UICorner")
    sliderBgCorner.CornerRadius = UDim.new(1, 0)
    sliderBgCorner.Parent = sliderBg
    
    local sliderFill = Instance.new("Frame")
    sliderFill.Parent = sliderBg
    sliderFill.BackgroundColor3 = GUI.Theme.Accent
    sliderFill.BorderSizePixel = 0
    sliderFill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    
    local sliderFillCorner = Instance.new("UICorner")
    sliderFillCorner.CornerRadius = UDim.new(1, 0)
    sliderFillCorner.Parent = sliderFill
    
    local dragButton = Instance.new("TextButton")
    dragButton.Parent = sliderBg
    dragButton.BackgroundTransparency = 1
    dragButton.Size = UDim2.new(1, 0, 1, 0)
    dragButton.Text = ""
    dragButton.ZIndex = 10
    
    local value = default
    local dragging = false
    
    local function updateSlider(input)
        local pos = input.Position.X - sliderBg.AbsolutePosition.X
        local percent = math.clamp(pos / sliderBg.AbsoluteSize.X, 0, 1)
        value = min + (max - min) * percent
        value = math.floor(value * 10) / 10 -- round to 1 decimal
        sliderFill.Size = UDim2.new(percent, 0, 1, 0)
        valueLabel.Text = tostring(value)
        if callback then callback(value) end
    end
    
    dragButton.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            updateSlider(input)
        end
    end)
    
    dragButton.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            updateSlider(input)
        end
    end)
    
    return value
end

-- Helper function to create a dropdown
function CreateDropdown(parentTab, text, options, default, callback)
    local frame = Instance.new("Frame")
    frame.Parent = parentTab
    frame.BackgroundColor3 = GUI.Theme.Secondary
    frame.BorderSizePixel = 0
    frame.Size = UDim2.new(1, -10, 0, 60)
    frame.Position = UDim2.new(0, 5, 0, 0)
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 4)
    corner.Parent = frame
    
    local label = Instance.new("TextLabel")
    label.Parent = frame
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(1, -20, 0, 20)
    label.Position = UDim2.new(0, 10, 0, 5)
    label.Text = text
    label.TextColor3 = GUI.Theme.Text
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    
    local dropButton = Instance.new("TextButton")
    dropButton.Parent = frame
    dropButton.BackgroundColor3 = GUI.Theme.Background
    dropButton.Size = UDim2.new(1, -20, 0, 25)
    dropButton.Position = UDim2.new(0, 10, 0, 25)
    dropButton.Text = "Select..."
    dropButton.TextColor3 = GUI.Theme.TextDim
    dropButton.Font = Enum.Font.Gotham
    dropButton.TextSize = 14
    dropButton.ZIndex = 5
    
    local dropCorner = Instance.new("UICorner")
    dropCorner.CornerRadius = UDim.new(0, 4)
    dropCorner.Parent = dropButton
    
    local dropdownList = Instance.new("Frame")
    dropdownList.Parent = frame
    dropdownList.BackgroundColor3 = GUI.Theme.Background
    dropdownList.BorderSizePixel = 0
    dropdownList.Size = UDim2.new(1, -20, 0, 0)
    dropdownList.Position = UDim2.new(0, 10, 0, 55)
    dropdownList.Visible = false
    dropdownList.ZIndex = 10
    dropdownList.ClipsDescendants = true
    
    local listLayout = Instance.new("UIListLayout")
    listLayout.Parent = dropdownList
    listLayout.SortOrder = Enum.SortOrder.LayoutOrder
    
    local function closeDropdown()
        dropdownList.Visible = false
    end
    
    dropButton.MouseButton1Click:Connect(function()
        dropdownList.Visible = not dropdownList.Visible
    end)
    
    for _, opt in ipairs(options) do
        local optBtn = Instance.new("TextButton")
        optBtn.Parent = dropdownList
        optBtn.BackgroundColor3 = GUI.Theme.Background
        optBtn.Size = UDim2.new(1, 0, 0, 25)
        optBtn.Text = opt
        optBtn.TextColor3 = GUI.Theme.Text
        optBtn.Font = Enum.Font.Gotham
        optBtn.TextSize = 14
        optBtn.AutoButtonColor = false
        optBtn.ZIndex = 11
        
        optBtn.MouseButton1Click:Connect(function()
            dropButton.Text = opt
            if callback then callback(opt) end
            closeDropdown()
        end)
        
        local optCorner = Instance.new("UICorner")
        optCorner.CornerRadius = UDim.new(0, 4)
        optCorner.Parent = optBtn
    end
    
    -- Adjust dropdown height based on options
    dropdownList.Size = UDim2.new(1, -20, 0, #options * 25)
    
    return dropdownList
end

